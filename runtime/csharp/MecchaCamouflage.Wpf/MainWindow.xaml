<Window x:Class="MecchaCamouflage.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Meccha Camouflage"
        MinWidth="960"
        MinHeight="640"
        Width="1040"
        Height="720"
        Background="#121212">
  <Window.Resources>
    <Style TargetType="TextBlock">
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style TargetType="TextBox">
      <Setter Property="Margin" Value="0,1,0,1" />
      <Setter Property="Padding" Value="5,3" />
    </Style>
    <Style TargetType="ComboBox">
      <Setter Property="Margin" Value="0,1,0,1" />
      <Setter Property="Padding" Value="4,2" />
    </Style>
    <Style TargetType="Button">
      <Setter Property="Margin" Value="0,0,6,6" />
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="MinWidth" Value="72" />
    </Style>
    <Style x:Key="SegmentRadioStyle" TargetType="RadioButton">
      <Setter Property="Foreground" Value="#EDEDED" />
      <Setter Property="Background" Value="#202020" />
      <Setter Property="BorderBrush" Value="#555" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="10,4" />
      <Setter Property="Margin" Value="0,0,4,0" />
      <Setter Property="MinWidth" Value="72" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RadioButton">
            <Border x:Name="Root"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="3"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Root" Property="Background" Value="#2B5F70" />
                <Setter TargetName="Root" Property="BorderBrush" Value="#54B6CF" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.55" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="42" />
      <RowDefinition Height="*" />
      <RowDefinition Height="28" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="#080808" BorderBrush="#555" BorderThickness="0,0,0,1">
      <DockPanel LastChildFill="True" Margin="12,0">
        <TextBlock x:Name="TitleText" Foreground="#F2F3F4" FontSize="17" FontWeight="SemiBold" VerticalAlignment="Center" />
      </DockPanel>
    </Border>

    <Grid Grid.Row="1" Margin="10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition MinWidth="480" Width="0.44*" />
        <ColumnDefinition Width="14" />
        <ColumnDefinition MinWidth="380" Width="0.56*" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" BorderBrush="#555" BorderThickness="1" Background="#161616">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="12">
            <TextBlock x:Name="PaintSettingsHeader" Foreground="#EDEDED" FontWeight="SemiBold" Margin="0,0,0,8" />

            <Grid Margin="0,0,0,4">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock x:Name="BrushLabel" Foreground="#D7D7D7" />
              <TextBox x:Name="BrushTextBox" Grid.Column="1" />
            </Grid>
            <Grid Margin="0,0,0,4">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock x:Name="CoverageLabel" Foreground="#D7D7D7" />
              <TextBox x:Name="CoverageTextBox" Grid.Column="1" />
            </Grid>
            <Grid Margin="0,0,0,4">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock x:Name="DelayLabel" Foreground="#D7D7D7" />
              <TextBox x:Name="DelayTextBox" Grid.Column="1" />
            </Grid>

            <CheckBox x:Name="AutoMaterialBox" Foreground="#D7D7D7" Margin="0,6,0,4" />
            <Grid Margin="0,0,0,4">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock x:Name="MetallicLabel" Foreground="#D7D7D7" />
              <TextBox x:Name="MetallicTextBox" Grid.Column="1" />
            </Grid>
            <Grid Margin="0,0,0,10">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock x:Name="RoughnessLabel" Foreground="#D7D7D7" />
              <TextBox x:Name="RoughnessTextBox" Grid.Column="1" />
            </Grid>

            <TextBlock x:Name="RegionsHeader" Foreground="#EDEDED" FontWeight="SemiBold" Margin="0,5,0,6" />
            <Grid Margin="0,0,0,4">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock x:Name="FrontLabel" Foreground="#D7D7D7" />
              <StackPanel Grid.Column="1" Orientation="Horizontal">
                <RadioButton x:Name="FrontPaintRadio" GroupName="FrontRegionMode" Style="{StaticResource SegmentRadioStyle}" Checked="RegionRadioChanged" />
                <RadioButton x:Name="FrontFillRadio" GroupName="FrontRegionMode" Style="{StaticResource SegmentRadioStyle}" Checked="RegionRadioChanged" />
                <RadioButton x:Name="FrontSkipRadio" GroupName="FrontRegionMode" Style="{StaticResource SegmentRadioStyle}" Checked="RegionRadioChanged" />
              </StackPanel>
            </Grid>
            <Grid Margin="0,0,0,4">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock x:Name="SidesLabel" Foreground="#D7D7D7" />
              <StackPanel Grid.Column="1" Orientation="Horizontal">
                <RadioButton x:Name="SidePaintRadio" GroupName="SideRegionMode" Style="{StaticResource SegmentRadioStyle}" Checked="RegionRadioChanged" />
                <RadioButton x:Name="SideFillRadio" GroupName="SideRegionMode" Style="{StaticResource SegmentRadioStyle}" Checked="RegionRadioChanged" />
                <RadioButton x:Name="SideSkipRadio" GroupName="SideRegionMode" Style="{StaticResource SegmentRadioStyle}" Checked="RegionRadioChanged" />
              </StackPanel>
            </Grid>
            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock x:Name="BackLabel" Foreground="#D7D7D7" />
              <StackPanel Grid.Column="1" Orientation="Horizontal">
                <RadioButton x:Name="BackPaintRadio" GroupName="BackRegionMode" Style="{StaticResource SegmentRadioStyle}" Checked="RegionRadioChanged" />
                <RadioButton x:Name="BackFillRadio" GroupName="BackRegionMode" Style="{StaticResource SegmentRadioStyle}" Checked="RegionRadioChanged" />
                <RadioButton x:Name="BackSkipRadio" GroupName="BackRegionMode" Style="{StaticResource SegmentRadioStyle}" Checked="RegionRadioChanged" />
              </StackPanel>
            </Grid>

            <StackPanel x:Name="FillMaterialPanel" Margin="0,4,0,12">
              <TextBlock x:Name="FillMaterialHeader" Foreground="#EDEDED" FontWeight="SemiBold" Margin="0,0,0,6" />
              <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="190" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="FillColorLabel" Foreground="#D7D7D7" />
                <TextBox x:Name="FillColorTextBox" Grid.Column="1" />
              </Grid>
              <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="190" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="FillMetallicLabel" Foreground="#D7D7D7" />
                <TextBox x:Name="FillMetallicTextBox" Grid.Column="1" />
              </Grid>
              <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="190" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="FillRoughnessLabel" Foreground="#D7D7D7" />
                <TextBox x:Name="FillRoughnessTextBox" Grid.Column="1" />
              </Grid>
            </StackPanel>

            <TextBlock x:Name="AppSettingsHeader" Foreground="#EDEDED" FontWeight="SemiBold" Margin="0,8,0,8" />
            <Grid Margin="0,0,0,4">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock x:Name="LanguageLabel" Foreground="#D7D7D7" />
              <ComboBox x:Name="LanguageBox" Grid.Column="1" SelectionChanged="LanguageChanged" />
            </Grid>
            <Grid Margin="0,0,0,4">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock x:Name="ProcessNameLabel" Foreground="#D7D7D7" />
              <TextBox x:Name="ProcessNameTextBox" Grid.Column="1" />
            </Grid>
            <Grid Margin="0,0,0,4">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock x:Name="StartHotkeyLabel" Foreground="#D7D7D7" />
              <TextBox x:Name="StartHotkeyTextBox" Grid.Column="1" />
            </Grid>
            <Grid Margin="0,0,0,4">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock x:Name="PreviewHotkeyLabel" Foreground="#D7D7D7" />
              <TextBox x:Name="PreviewHotkeyTextBox" Grid.Column="1" />
            </Grid>
            <Grid Margin="0,0,0,4">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock x:Name="UnPreviewHotkeyLabel" Foreground="#D7D7D7" />
              <TextBox x:Name="UnPreviewHotkeyTextBox" Grid.Column="1" />
            </Grid>
            <Grid Margin="0,0,0,4">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock x:Name="StopHotkeyLabel" Foreground="#D7D7D7" />
              <TextBox x:Name="StopHotkeyTextBox" Grid.Column="1" />
            </Grid>
            <CheckBox x:Name="AlwaysOnTopBox" Foreground="#D7D7D7" Margin="0,6,0,4" />
            <Grid Margin="0,0,0,4">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock x:Name="OpacityLabel" Foreground="#D7D7D7" />
              <Slider x:Name="OpacitySlider" Grid.Column="1" Minimum="35" Maximum="100" TickFrequency="5" IsSnapToTickEnabled="False" />
            </Grid>

            <WrapPanel Margin="0,10,0,0">
              <Button x:Name="EditButton" Click="EditClicked" />
              <Button x:Name="SaveButton" Click="SaveClicked" />
              <Button x:Name="CancelButton" Click="CancelClicked" />
              <Button x:Name="ResetButton" Click="ResetClicked" />
            </WrapPanel>
          </StackPanel>
        </ScrollViewer>
      </Border>

      <Grid Grid.Column="2">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <UniformGrid Grid.Row="0" Columns="3" Margin="0,0,0,10">
          <Border BorderBrush="#555" BorderThickness="1" Background="#181818" Margin="0,0,6,0" Padding="10">
            <StackPanel>
              <TextBlock x:Name="ProcessStatusLabel" Foreground="#999" />
              <TextBlock x:Name="ProcessStatusValue" Foreground="#EDEDED" FontSize="15" FontWeight="SemiBold" Text="-" />
            </StackPanel>
          </Border>
          <Border BorderBrush="#555" BorderThickness="1" Background="#181818" Margin="0,0,6,0" Padding="10">
            <StackPanel>
              <TextBlock x:Name="BridgeStatusLabel" Foreground="#999" />
              <TextBlock x:Name="BridgeStatusValue" Foreground="#EDEDED" FontSize="15" FontWeight="SemiBold" Text="-" />
            </StackPanel>
          </Border>
          <Border BorderBrush="#555" BorderThickness="1" Background="#181818" Margin="0,0,6,0" Padding="10">
            <StackPanel>
              <TextBlock x:Name="ServiceStatusLabel" Foreground="#999" />
              <TextBlock x:Name="ServiceStatusValue" Foreground="#EDEDED" FontSize="15" FontWeight="SemiBold" Text="-" />
            </StackPanel>
          </Border>
        </UniformGrid>

        <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,10">
          <Border BorderBrush="#444" BorderThickness="1" Background="#141414" Margin="0,0,6,0" Padding="10">
            <StackPanel>
              <TextBlock x:Name="PaintStatusLabel" Foreground="#999" />
              <TextBlock x:Name="PaintStatusValue" Foreground="#EDEDED" FontSize="15" FontWeight="SemiBold" Text="-" />
            </StackPanel>
          </Border>
          <Border BorderBrush="#444" BorderThickness="1" Background="#141414" Margin="0,0,6,0" Padding="10">
            <StackPanel>
              <TextBlock x:Name="PaintEtaLabel" Foreground="#999" />
              <TextBlock x:Name="PaintEtaValue" Foreground="#EDEDED" FontSize="15" FontWeight="SemiBold" Text="-" />
            </StackPanel>
          </Border>
          <Border BorderBrush="#444" BorderThickness="1" Background="#141414" Padding="10">
            <StackPanel>
              <TextBlock x:Name="PaintElapsedLabel" Foreground="#999" />
              <TextBlock x:Name="PaintElapsedValue" Foreground="#EDEDED" FontSize="15" FontWeight="SemiBold" Text="-" />
            </StackPanel>
          </Border>
        </UniformGrid>

        <WrapPanel Grid.Row="2" Margin="0,0,0,10">
          <Button x:Name="StartButton" Click="StartClicked" />
          <Button x:Name="StopButton" Click="StopClicked" />
          <Button x:Name="OpenLogsButton" Click="OpenLogsClicked" />
          <Button x:Name="CopyLogButton" Click="CopyLogClicked" />
        </WrapPanel>

        <Border Grid.Row="3" BorderBrush="#555" BorderThickness="1" Background="#0C0C0C">
          <DockPanel>
            <TextBlock x:Name="LogsHeader" DockPanel.Dock="Top" Foreground="#EDEDED" FontWeight="SemiBold" Margin="10,8,10,4" />
            <TextBox x:Name="LogTextBox"
                     FontFamily="Consolas"
                     FontSize="12"
                     Foreground="#EDEDED"
                     Background="#0C0C0C"
                     BorderThickness="0"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     Margin="8" />
          </DockPanel>
        </Border>
      </Grid>
    </Grid>

    <Border Grid.Row="2" Background="#080808" BorderBrush="#555" BorderThickness="0,1,0,0">
      <DockPanel Margin="12,0">
        <TextBlock x:Name="FooterVersionText" DockPanel.Dock="Right" Foreground="#999" />
        <TextBlock Foreground="#999">
          <Run x:Name="FooterCopyrightRun" />
          <Run Text=" | " />
          <Hyperlink NavigateUri="https://github.com/acentrist/MecchaCamouflage/blob/main/LICENSE.txt"
                     RequestNavigate="FooterLinkNavigate">
            <Run Text="License" />
          </Hyperlink>
          <Run Text=" | " />
          <Hyperlink NavigateUri="https://github.com/acentrist/MecchaCamouflage"
                     RequestNavigate="FooterLinkNavigate">
            <Run Text="GitHub" />
          </Hyperlink>
        </TextBlock>
      </DockPanel>
    </Border>
  </Grid>
</Window>
